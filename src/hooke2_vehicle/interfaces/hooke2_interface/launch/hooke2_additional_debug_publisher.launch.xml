<launch>
  <arg name="input_topic" default="/hooke2/can_tx"/>
  <arg name="output_topic" default="/hooke2/debug"/>
  <arg name="output_accel_cal_topic" default="/hooke2/accel_cal_rpt"/>
  <arg name="output_brake_cal_topic" default="/hooke2/brake_cal_rpt"/>
  <arg name="output_steer_cal_topic" default="/hooke2/steer_cal_rpt"/>
  <arg name="calibration_active" default="false"/>
  <node pkg="hooke2_interface" exec="hooke2_additional_debug_publisher" name="hooke2_additional_debug_publisher" output="screen">
    <remap from="input/can_tx" to="$(var input_topic)"/>
    <remap from="output/debug" to="$(var output_topic)"/>
    <remap from="output/accel_cal_rpt" to="$(var output_accel_cal_topic)"/>
    <remap from="output/brake_cal_rpt" to="$(var output_brake_cal_topic)"/>
    <remap from="output/steer_cal_rpt" to="$(var output_steer_cal_topic)"/>
    <param name="calibration_active" value="$(var calibration_active)"/>
  </node>
</launch>
