<?xml version="1.0"?>
<launch>
  <!-- For Hooke2 Steer Test -->

  <arg name="vehicle_model" description="vehicle model name"/>
  <arg name="hooke2_param_path" default="$(find-pkg-share hooke2_interface)/config/hooke2_steer_test.param.yaml"/>

  <!-- vehicle info param -->
  <include file="$(find-pkg-share global_parameter_loader)/launch/global_params.launch.py">
    <arg name="vehicle_model" value="$(var vehicle_model)"/>
  </include>

  <!-- hooke2 steer test -->
  <node pkg="hooke2_interface" exec="hooke2_steer_test" name="hooke2_steer_test" output="screen">
    <param from="$(var hooke2_param_path)"/>
  </node>

  <!-- hooke2 -->
  <group>
    <include file="$(find-pkg-share $(var vehicle_model)_description)/launch/hooke2.launch.py"/>
  </group>
</launch>
