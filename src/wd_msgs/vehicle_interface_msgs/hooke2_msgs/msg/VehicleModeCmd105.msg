# Vehicle Mode cmd system

std_msgs/Header header

# Control Message
# Turn light cmd
uint8 TURN_LIGHT_CTRL_TURNLAMP_OFF = 0
uint8 TURN_LIGHT_CTRL_LEFT_TURNLAMP_ON = 1
uint8 TURN_LIGHT_CTRL_RIGHT_TURNLAMP_ON = 2
uint8 TURN_LIGHT_CTRL_HAZARD_WARNING_LAMPSTS_ON = 3

# Vin request enable cmd
uint8 VIN_REQ_VIN_REQ_DISABLE = 0
uint8 VIN_REQ_VIN_REQ_ENABLE = 1

# Drive mode cmd
uint8 DRIVE_MODE_CTRL_THROTTLE_PADDLE_DRIVE = 0
uint8 DRIVE_MODE_CTRL_SPEED_DRIVE = 1

# Steer mode cmd
uint8 STEER_MODE_CTRL_STANDARD_STEER = 0
uint8 STEER_MODE_CTRL_NON_DIRECTION_STEER = 1
uint8 STEER_MODE_CTRL_SYNC_DIRECTION_STEER = 2

int32 checksum_105		#  [0|255]
uint8 turn_light_ctrl		#  vehicle turn light cmd, 0-TURN_LIGHT_CTRL_TURNLAMP_OFF, 1-TURN_LIGHT_CTRL_LEFT_TURNLAMP_ON, 2-TURN_LIGHT_CTRL_RIGHT_TURNLAMP_ON, 3-TURN_LIGHT_CTRL_HAZARD_WARNING_LAMPSTS_ON
uint8 vin_req			#  request vin cmd,0-VIN_REQ_VIN_REQ_DISABLE, 1-VIN_REQ_VIN_REQ_ENABLE
uint8 drive_mode_ctrl		#  vehicle drive mode cmd,0-DRIVE_MODE_CTRL_THROTTLE_PADDLE_DRIVE, 1-DRIVE_MODE_CTRL_SPEED_DRIVE
uint8 steer_mode_ctrl		#  vehicle steer mode cmd,0-STEER_MODE_CTRL_STANDARD_STEER, 1-STEER_MODE_CTRL_NON_DIRECTION_STEER, 2-STEER_MODE_CTRL_SYNC_DIRECTION_STEER
