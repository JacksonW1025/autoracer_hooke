<?xml version="1.0" encoding="UTF-8"?>
<launch>
  <arg name="brand" default="3" description="brand: SOCKET = 0,INNODISK = 1, ESD = 2, KVASER = 3"/>
  <arg name="type" default="0" description="type: PCI_CARD = 0,USB_CARD = 1" />
  <arg name="channel_id" default="0" description="channel_id: 0,1" />
  <arg name="interface" default="0" description="interface: NATIVE = 0, VIRTUAL = 1, SLCAN = 2" />
  <arg name="baudrate" default="250000" description="baudrate: BITRATE_500K = 500000" />
  <arg name="dev_id" default="24" description="dev_id: ttyACM0 = 24, ttyACM1 = 25, ttyACM2 = 26" />
  <arg name="frame_id" default="can_driver" />
  <arg name="can_rx_topic" default="can_rx" />
  <arg name="can_tx_topic" default="can_tx" />

  <node pkg="can_driver" exec="can_driver" name="can_driver" output="screen">
    <param name="brand" value="$(var brand)" />
    <param name="type" value="$(var type)" />
    <param name="channel_id" value="$(var channel_id)" />
    <param name="interface" value="$(var interface)" />
    <param name="baudrate" value="$(var baudrate)" />
    <param name="dev_id" value="$(var dev_id)" />
    <param name="frame_id" value="$(var frame_id)" />
    <param name="can_rx_topic" value="$(var can_rx_topic)" />
    <param name="can_tx_topic" value="$(var can_tx_topic)" />

