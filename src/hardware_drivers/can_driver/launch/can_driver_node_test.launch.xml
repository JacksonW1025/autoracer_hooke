<?xml version="1.0" encoding="UTF-8"?>
<launch>
  <arg name="brand" default="0" type="int" />      <!-- brand: SOCKET = 0,INNODISK = 1, ESD = 2 -->
  <arg name="type" default="0" type="int" />       <!-- type: PCI_CARD = 0,USB_CARD = 1 -->
  <arg name="channel_id" default="0" type="int"  /> <!-- channel_id: 0,1-->
  <arg name="interface" default="1" type="int" />  <!-- interface: NATIVE = 0, VIRTUAL = 1, SLCAN = 2 -->
  <arg name="baudrate" default="500000" type="int" />   <!-- baudrate: BITRATE_500K = 500000 -->
  <arg name="dev_id" default="24" type="int" />    <!-- dev_id: ttyACM0 = 24, ttyACM1 = 25, ttyACM2 = 26 -->
  <arg name="can_rx_topic" default="can_rx" type="string" />
  <arg name="can_tx_topic" default="can_tx" type="string" />

  <node pkg="can_driver" exec="can_driver_node" name="can_driver_node" output="screen">
    <param name="brand" type="int" value="$(arg brand)" />
    <param name="type" type="int" value="$(arg type)" />
    <param name="channel_id" type="int" value="$(arg channel_id)" />
    <param name="interface" type="int" value="$(arg interface)" />
    <param name="baudrate" type="int" value="$(arg baudrate)" />
    <param name="dev_id" type="int" value="$(arg dev_id)" />
    <param name="can_rx_topic" type="string" value="$(arg can_rx_topic)" />
    <param name="can_tx_topic" type="string" value="$(arg can_tx_topic)" />

    <!-- <param name="brand" type="int" value="2" />
    <param name="type" type="int" value="0" />
    <param name="channel_id" type="int" value="0" />
    <param name="interface" type="int" value="0" />
    <param name="baudrate" type="int" value="500000" />
    <param name="dev_id" type="int" value="24" />
    <param name="can_rx_topic" type="string" value="can_rx" />
    <param name="can_tx_topic" type="string" value="can_tx" /> -->

  </node>
</launch>

